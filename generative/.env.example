# Required: where generated notes are written (your Obsidian vault).
# Use an absolute path for your OS:
#   macOS/Linux:  /Users/you/ObsidianVault   or   /home/you/ObsidianVault
#   Windows:      C:/Users/you/ObsidianVault
ATOMIC_AGENT_VAULT_PATH=/path/to/your/ObsidianVault

# Optional: base folder for source PDFs (same path rules as above).
ATOMIC_AGENT_PDF_BASE=/path/to/your/Literatur

# Optional: contact identifier written into note provenance (leave as-is if unsure).
ATOMIC_AGENT_CONTACT=your-email@example.com

# Backend: subscription (default, Claude Code CLI) | litellm (API-based)
ATOMIC_AGENT_BACKEND=subscription

# Model overrides (optional). Leave these commented to use the sane defaults from
# config.py: sonnet for the heavy slot (lower hallucination, ~5x cheaper than opus),
# haiku for the light stages. Uncomment only to deliberately override.
# ATOMIC_AGENT_MODEL_OPUS=anthropic/claude-sonnet-4-6
# ATOMIC_AGENT_MODEL_HAIKU=anthropic/claude-haiku-4-5-20251001

# Provider keys (only needed for ATOMIC_AGENT_BACKEND=litellm)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=AIza...
# OLLAMA_API_BASE=http://localhost:11434   # optional, default already localhost
