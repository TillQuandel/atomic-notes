ATOMIC_AGENT_VAULT_PATH=C:/Users/yourname/YourVault
ATOMIC_AGENT_PDF_BASE=C:/Users/yourname/Documents/Literatur
ATOMIC_AGENT_CONTACT=your-email@example.com

# Backend-Switch: subscription (default, claude CLI) | litellm (API-basiert)
ATOMIC_AGENT_BACKEND=subscription

# Modell-IDs (litellm-kompatibel, auch für subscription genutzt)
# subscription-Backend mappt diese intern auf CLI-Shorthand (opus/haiku)
ATOMIC_AGENT_MODEL_OPUS=anthropic/claude-opus-4-7
ATOMIC_AGENT_MODEL_HAIKU=anthropic/claude-haiku-4-5-20251001

# Provider-Keys (nur bei ATOMIC_AGENT_BACKEND=litellm nötig)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=AIza...
# OLLAMA_API_BASE=http://localhost:11434   # optional, default bereits localhost
